# Turso Database Configuration
# Get these values from: https://turso.tech/
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Vercel Blob Storage
# This is automatically set when you connect Blob storage in Vercel dashboard
BLOB_READ_WRITE_TOKEN=your-blob-token

# NextAuth
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret

# Resend (email verification)
# Get from: https://resend.com/
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=onboarding@yourdomain.com

# Public app URL — used for verification email links
# Use http://localhost:3000 in development, https://app.clienthappy.com in production
NEXT_PUBLIC_APP_URL=http://localhost:3000
